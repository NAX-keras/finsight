# ================================================================
# FinSight Backend  —  .env.example
# Salin file ini:  cp .env.example .env
# Lalu edit nilai yang ditandai ← WAJIB DIISI
# ================================================================

# ── Aplikasi ────────────────────────────────────────────────────
APP_NAME=FinSight Backend
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ── Server ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── PostgreSQL  ← WAJIB DIISI ──────────────────────────────────
# Sesuaikan user, password, host, port, dan nama database Anda
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finsight_db
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/finsight_db

# ── CORS ─────────────────────────────────────────────────────────
# Frontend React Vite default berjalan di port 5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ── Anthropic API  ← ISI jika ingin fitur /api/chat aktif ──────
# Dapatkan key di: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── AI Model — Keras LSTM ────────────────────────────────────────
# Path relatif dari folder backend/
# File model sudah tersedia di ai_models/finsight_model.keras
PREDICTION_MODEL_PATH=ai_models/finsight_model.keras

# ── AI Model — Sentimen (opsional .pkl scikit-learn) ────────────
# Jika file tidak ada, backend pakai rule-based fallback otomatis
SENTIMENT_MODEL_PATH=ai_models/sentiment_model.pkl

# ── Logging ──────────────────────────────────────────────────────
# Pilihan: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
