# .env.example
# Salin file ini menjadi .env dan isi nilainya

# URL backend kamu (FastAPI / Node / dll)
# Jika tidak ada backend, biarkan kosong — akan pakai data statis
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api

# Anthropic API Key (hanya untuk development tanpa backend)
# Di production, sebaiknya proxy via backend agar key tidak expose
VITE_ANTHROPIC_API_KEY=your_api_key_here
